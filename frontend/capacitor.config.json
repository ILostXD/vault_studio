{
  "appId": "com.vaultstudio.app",
  "appName": "{ vault.studio }",
  "webDir": "dist",
  "server": {
    "hostname": "localhost",
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true
  },
  "plugins": {
    "SystemBars": {
      "insetsHandling": "disable"
    },
    "EdgeToEdge": {
      "statusBarColor": "#121212",
      "navigationBarColor": "#121212"
    }
  }
}
